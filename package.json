{
  "name": "business-links",
  "version": "2.7.0",
  "description": "Streamlines navigation with external links, dashboards, and dropdowns.",
  "author": "Grafana Labs",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "webpack -c ./webpack.config.ts --env production",
    "dev": "webpack -w -c ./webpack.config.ts --env development",
    "levitate": "npx @grafana/levitate@latest is-compatible --path src/module.ts --target @grafana/data,@grafana/runtime,@grafana/ui",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "mcp:finance": "cd mcp/server-finance && npm run dev",
    "mcp:weather": "cd mcp/server-weather && npm run dev",
    "server": "docker compose up --build",
    "sign": "sign-plugin",
    "start": "docker compose pull grafana && docker compose --profile dev up",
    "stop": "docker compose down",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "test:e2e": "npx playwright test",
    "test:e2e:dev": "npx playwright test --ui",
    "test:e2e:docker": "docker compose --profile playwright up --exit-code-from playwright",
    "typecheck": "tsc --noEmit",
    "upgrade": "npm upgrade --save"
  },
  "dependencies": {
    "@emotion/css": "11.10.6",
    "@grafana/data": "12.3.6",
    "@grafana/i18n": "12.3.6",
    "@grafana/llm": "0.22.1",
    "@grafana/runtime": "12.3.6",
    "@grafana/scenes": "6.57.2",
    "@grafana/schema": "12.3.6",
    "@grafana/ui": "12.3.6",
    "@hello-pangea/dnd": "18.0.1",
    "@volkovlabs/components": "4.6.0",
    "dayjs": "1.11.21",
    "handlebars": "4.7.9",
    "helper-date": "1.0.1",
    "markdown-it": "14.2.0",
    "pg": "8.22.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-grid-layout": "2.2.3",
    "rxjs": "7.8.2",
    "semver": "7.8.5",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@grafana/eslint-config": "9.0.0",
    "@grafana/plugin-e2e": "3.9.1",
    "@grafana/sign-plugin": "3.3.1",
    "@grafana/tsconfig": "2.2.0",
    "@playwright/test": "1.61.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.15.43",
    "@swc/helpers": "0.5.23",
    "@swc/jest": "0.2.39",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "29.5.14",
    "@types/lodash": "4.17.24",
    "@types/markdown-it": "14.1.2",
    "@types/node": "24.13.2",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@types/react-grid-layout": "1.3.6",
    "@types/semver": "7.7.1",
    "@types/testing-library__jest-dom": "5.14.9",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
