{
  "name": "business-links",
  "version": "2.6.2",
  "description": "Streamlines navigation with external links, dashboards, and dropdowns.",
  "author": "Grafana Labs",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "e2e": "playwright test",
    "levitate": "npx @grafana/levitate@latest is-compatible --path src/module.ts --target @grafana/data,@grafana/runtime,@grafana/ui",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "mcp:finance": "cd mcp/server-finance && npm run dev",
    "mcp:weather": "cd mcp/server-weather && npm run dev",
    "server": "docker compose up --build",
    "sign": "sign-plugin",
    "start": "docker compose pull grafana && docker compose --profile dev up",
    "stop": "docker compose down",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "test:e2e": "npx playwright test",
    "test:e2e:dev": "npx playwright test --ui",
    "test:e2e:docker": "docker compose --profile e2e up --exit-code-from test",
    "typecheck": "tsc --noEmit",
    "upgrade": "npm upgrade --save"
  },
  "dependencies": {
    "@emotion/css": "11.10.6",
    "@grafana/data": "12.3.6",
    "@grafana/i18n": "12.3.6",
    "@grafana/llm": "^0.22.1",
    "@grafana/runtime": "12.3.6",
    "@grafana/scenes": "^6.28.6",
    "@grafana/schema": "12.3.6",
    "@grafana/ui": "12.3.6",
    "@hello-pangea/dnd": "^18.0.1",
    "@volkovlabs/components": "^4.6.0",
    "dayjs": "^1.11.13",
    "handlebars": "^4.7.8",
    "helper-date": "^1.0.1",
    "markdown-it": "^14.1.0",
    "pg": "^8.22.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-grid-layout": "2.2.3",
    "rxjs": "7.8.2",
    "semver": "^7.7.2",
    "tslib": "^2.8.0"
  },
  "devDependencies": {
    "@grafana/eslint-config": "^9.0.0",
    "@grafana/plugin-e2e": "^3.9.1",
    "@grafana/sign-plugin": "^3.2.2",
    "@grafana/tsconfig": "^2.0.1",
    "@playwright/test": "^1.61.1",
    "@stylistic/eslint-plugin": "^5.2.2",
    "@stylistic/eslint-plugin-ts": "^4.4.0",
    "@swc/core": "^1.15.0",
    "@swc/helpers": "^0.5.0",
    "@swc/jest": "^0.2.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.17.16",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-grid-layout": "^1.3.5",
    "@types/semver": "^7.7.0",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@volkovlabs/eslint-config": "^2.0.0",
    "@volkovlabs/jest-selectors": "^1.5.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-jsdoc": "^52.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-webpack-plugin": "^5.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^11.1.0",
    "identity-obj-proxy": "^3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.6.0",
    "replace-in-file-webpack-plugin": "^1.0.0",
    "sass": "^1.89.0",
    "sass-loader": "^16.0.0",
    "semver": "^7.7.0",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.0",
    "terser-webpack-plugin": "^5.3.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "5.9.2",
    "webpack": "^5.101.0",
    "webpack-cli": "^6.0.0",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "packageManager": "npm@11.13.0"
}
